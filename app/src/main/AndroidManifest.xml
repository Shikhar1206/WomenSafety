<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.womensafety">

    <!-- Communication -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Camera & Microphone -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Vibration -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake Lock for background services -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".WomenSafetyApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:theme="@style/Theme.WomenSafety"
        android:icon="@mipmap/ic_calendar"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true">

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- LAUNCHER: Calendar disguise screen -->
        <activity
            android:name=".presentation.calendar.CalendarActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MAIN: Single-activity host for Compose navigation -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Fake Call -->
        <activity
            android:name=".presentation.fakecall.FakeCallActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true" />

        <!-- Services -->
        <service
            android:name=".service.EmergencyService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <service
            android:name=".service.PhotoCaptureService"
            android:foregroundServiceType="camera"
            android:exported="false" />

        <service
            android:name=".service.SafeWordService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <service
            android:name=".service.LocationTrackingService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- Firebase Cloud Messaging -->
        <service
            android:name=".data.remote.firebase.FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Receivers -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.BatteryReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BATTERY_CHANGED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.SosActionReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.womensafety.CANCEL_SOS" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
