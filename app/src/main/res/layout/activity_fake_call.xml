<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C0D14"
    android:padding="24dp">

    <!-- Incoming Call Text -->
    <TextView
        android:id="@+id/tvIncoming"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INCOMING CALL"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#9090B0"
        android:letterSpacing="0.15"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Caller Avatar Card Frame -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCallerAvatar"
        android:layout_width="128dp"
        android:layout_height="128dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="64dp"
        app:cardElevation="0dp"
        app:strokeWidth="2dp"
        app:strokeColor="#1E1E35"
        app:cardBackgroundColor="#131328"
        app:layout_constraintTop_toBottomOf="@id/tvIncoming"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgCaller"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_contact"
                app:tint="#D1D5DB"
                android:padding="12dp"
                android:contentDescription="Caller Avatar"/>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Caller Name -->
    <TextView
        android:id="@+id/tvCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mom"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#F3F3FA"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardCallerAvatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Caller Number -->
    <TextView
        android:id="@+id/tvCallerNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+91 12345 67890"
        android:textSize="16sp"
        android:textColor="#9090B0"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvCallerName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Simulated Dialer Utility Buttons (Realism Add-on) -->
    <LinearLayout
        android:id="@+id/layoutUtils"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/btnAnswer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reply with Message"
            android:textSize="12sp"
            android:textColor="#9090B0"
            android:textStyle="bold"
            android:background="@drawable/bg_rounded_dark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"/>
    </LinearLayout>

    <!-- Call Control Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnswer"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="64dp"
        app:cornerRadius="40dp"
        app:backgroundTint="#00E676"
        app:icon="@drawable/ic_call"
        app:iconTint="#FFFFFF"
        app:iconSize="32dp"
        app:iconGravity="textStart"
        android:padding="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnEndCall"
        app:layout_constraintHorizontal_chainStyle="spread"
        android:contentDescription="Answer Call"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEndCall"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="64dp"
        app:cornerRadius="40dp"
        app:backgroundTint="#FF3366"
        app:icon="@drawable/ic_call_end"
        app:iconTint="#FFFFFF"
        app:iconSize="32dp"
        app:iconGravity="textStart"
        android:padding="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnAnswer"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="End Call"/>

</androidx.constraintlayout.widget.ConstraintLayout>
